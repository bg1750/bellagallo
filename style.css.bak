/* ===== RESET ===== */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

/* ===== BASE ===== */
body {
    font-family: 'Inter', sans-serif;
    background-color: #31003C;
    color: #C8A79C;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

/* ===== LAYOUT: top nav + scrollable main ===== */
.layout-grid {
    display: flex;
    flex-direction: column;
    height: 100vh;
}

/* ===== TOP NAVBAR ===== */
.site-header {
    background-color: #4C066C;
    border-bottom: 1px solid #9940FF44;
    flex-shrink: 0;
}

.header-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 28px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
}

.nav-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: #9940FF;
    color: #31003C;
    font-family: 'Mea Culpa', cursive;
    font-size: 1.5em;
    text-decoration: none;
    border-radius: 10px;
    flex-shrink: 0;
    cursor: pointer;
    transition: background-color 0.2s;
}

.nav-logo:hover {
    background-color: #C8A79C;
}

.nav-list {
    list-style: none;
    display: flex;
    flex-direction: row; /* HORIZONTAL */
    gap: 4px;
    align-items: center;
}

/* Each nav item: relative so bubble fills it */
.nav-item {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
}

/* Purple bubble behind the active item */
.nav-bubble {
    position: absolute;
    inset: 0;
    background-color: #9940FF;
    border-radius: 10px;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 0;
    pointer-events: none;
}

.nav-item.active .nav-bubble {
    opacity: 1;
}

.nav-link {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    color: #C8A79C;
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: color 0.2s;
}

.nav-item.active .nav-link {
    color: #31003C;
    font-weight: 700;
}

.nav-item:not(.active):hover .nav-link {
    color: #9940FF;
}

.nav-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
}

/* ===== MAIN (scrollable) ===== */
main {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
}

/* ===== SCROLLBAR STYLING ===== */
main::-webkit-scrollbar,
.detail-scroll-area::-webkit-scrollbar {
    width: 4px;
}

main::-webkit-scrollbar-track,
.detail-scroll-area::-webkit-scrollbar-track {
    background: transparent;
}

main::-webkit-scrollbar-thumb,
.detail-scroll-area::-webkit-scrollbar-thumb {
    background: #9940FF44;
    border-radius: 999px;
}

main::-webkit-scrollbar-thumb:hover,
.detail-scroll-area::-webkit-scrollbar-thumb:hover {
    background: #9940FF99;
}

/* ===== PAGE SECTIONS ===== */
.page-section {
    display: none;
    min-height: 100%;
}

.page-section.active {
    display: block;
}

/* ===== WIDGET (shared card style) ===== */
.widget {
    background-color: #4C066C;
    border-radius: 16px;
    padding: 28px;
}

/* ===== HOME / HERO ===== */
.hero {
    position: relative;
    height: calc(100vh - 65px);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #34146C;
    overflow: hidden;
}

.top-flower {
    position: absolute;
    right: 20px;
    top: 20px;
    width: 220px;
    height: 220px;
    opacity: 0.6;
    pointer-events: none;
}

.bottom-flower {
    position: absolute;
    left: 20px;
    bottom: 20px;
    width: 220px;
    height: 220px;
    opacity: 0.6;
    pointer-events: none;
}

.hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    z-index: 1;
    text-align: center;
}

h1 {
    color: #9940FF;
    font-size: 4.5em;
    font-family: 'Mea Culpa', cursive;
    font-weight: bold;
    line-height: 1.1;
}

.hero-subtitle {
    font-size: 1.3em;
    color: #C8A79C;
    letter-spacing: 2px;
}

/* Modifier class applied to the second hero subtitle line to make it
   visually smaller than the "Computer Engineer" line above it */
.hero-subtitle--small {
    font-size: 0.95em;
}

.hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
}

.hero-btn {
    padding: 13px 36px;
    background-color: #9940FF;
    color: #31003C;
    border: 2px solid #9940FF;
    border-radius: 50px;
    font-weight: bold;
    font-size: 1em;
    cursor: pointer;
    transition: background-color 0.25s, border-color 0.25s, color 0.25s;
}

.hero-btn:hover {
    background-color: #C8A79C;
    border-color: #C8A79C;
    color: #31003C;
}

.hero-btn--outline {
    background-color: transparent;
    color: #C8A79C;
    border-color: #C8A79C;
}

.hero-btn--outline:hover {
    background-color: #C8A79C;
    color: #31003C;
}

/* ===== SECTION WRAPPER ===== */
.section-wrap {
    padding: 48px 40px;
    max-width: 1100px;
    margin: 0 auto;
}

.section-heading {
    color: #9940FF;
    font-size: 2em;
    margin-bottom: 32px;
}

/* ===== ABOUT ===== */
.about-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
}

.about-photo-widget {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
}

.profile-pic {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #9940FF;
    display: block;
}

.widget-heading {
    color: #9940FF;
    font-size: 1.6em;
    margin-bottom: 16px;
}

.body-text {
    color: #C8A79C;
    font-size: 1em;
    line-height: 1.8;
    text-align: left;
    display: block;
}

/* ===== PROJECTS =====
   All styles below were added to replace the old flip-card/carousel layout
   with a modern grid-based design inspired by evanqhuang.com. ===== */

/* --- Section header: "Selected Work" label + "Projects" heading on the left,
       filter buttons on the right --- */
.proj-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
}

/* Small monospace label above the Projects heading */
.proj-label {
    font-size: 0.75em;
    font-family: monospace;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9940FF;
    margin-bottom: 6px;
}

/* Main "Projects" heading */
.proj-heading {
    font-size: 2em;
    font-weight: bold;
    color: #C8A79C;
    line-height: 1.1;
}

/* Row of filter buttons that sit to the right of the heading */
.filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

/* --- Filter buttons: default (inactive) state --- */
.filter-btn {
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid #9940FF44;
    background-color: transparent;
    color: #C8A79C;
    font-size: 0.8em;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
}

/* Filter button on hover */
.filter-btn:hover {
    border-color: #9940FF;
    color: #9940FF;
}

/* Filter button when it is the currently selected category */
.filter-btn.filter-active {
    background-color: #9940FF;
    border-color: #9940FF;
    color: #31003C;
    font-weight: 600;
}

/* Hint text below projects header */
.proj-hint {
    font-size: 0.78rem;
    color: #C8A79C99;
    margin-bottom: 16px;
}

/* Decorative 1px gradient line between the header and the card grid */
.proj-divider {
    height: 1px;
    background: linear-gradient(to right, #9940FF66, #4C066C, transparent);
    margin-bottom: 32px;
}

/* 3-column responsive grid that holds the project cards */
.proj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

/* --- Project card: base style --- */
.proj-card {
    position: relative;
    background-color: #4C066C;
    border-radius: 12px;
    border: 1px solid #9940FF22; /* subtle border at rest */
    overflow: hidden;            /* clips the image and caption inside the rounded corners */
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    cursor: pointer;
    min-height: 280px;           /* consistent card height across the grid */
}

/* --- Hover effect: purple outline glow + slight lift --- */
.proj-card:hover {
    border-color: #9940FF;                               /* solid purple border */
    box-shadow: 0 0 0 1px #9940FF, 0 6px 28px #9940FF22; /* outer glow ring */
    transform: translateY(-3px);                         /* lifts card upward */
}

/* --- Title turns purple on hover (targets .proj-title inside a hovered card) --- */
.proj-card:hover .proj-title {
    color: #9940FF;
}

/* --- Stretched invisible link covering the entire card, so clicking anywhere opens the project detail page --- */
.proj-card-link {
    position: absolute;
    inset: 0;            /* fills the full card area */
    border-radius: 12px;
    z-index: 1;          /* above card content, but below the toggle button (z-index: 3) and links (z-index: 2) */
}

/* ===== CARD FRONT (image view — shown by default) ===== */

/* Front face fills the full card */
.proj-card-front {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    min-height: 280px;
}

/* Image area fills the available space above the caption */
.proj-card-img {
    width: 100%;
    flex: 1;
    min-height: 0;
}

/* Image tag inside .proj-card-img — covers the full area */
.proj-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* Placeholder shown until a real screenshot is added */
.proj-img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #31003C;
    border: 2px dashed #9940FF33;
    color: #9940FF55;
    font-family: monospace;
    font-size: 0.8em;
}

/* Caption panel sitting below the image */
.proj-card-caption {
    padding: 12px 20px;
    background: rgba(49, 0, 60, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-top: 1px solid #9940FF33;
    border-radius: 0 0 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
}

/* ===== CARD BACK (description view — hidden until + is clicked) ===== */

/* Back face hidden by default; shown when .proj-card has the .flipped class */
.proj-card-back {
    display: none;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    height: 100%;
    min-height: 280px;
}

/* When .flipped is added by JS: hide the front, show the back */
.proj-card.flipped .proj-card-front { display: none; }
.proj-card.flipped .proj-card-back  { display: flex; }

/* ===== TOGGLE BUTTON (+ / −) ===== */

/* Positioned in the top-right corner of the card.
   z-index: 3 keeps it above both the card link (z-index: 1) and the GitHub links (z-index: 2)
   so it always captures its own click events. */
.proj-toggle-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 3;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #9940FF;
    color: #31003C;
    border: none;
    font-size: 1.1em;
    font-weight: bold;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
}

.proj-toggle-btn:hover {
    background-color: #C8A79C;
}

/* Top section of each card: stacks category label above the title */
.proj-card-top {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

/* Small uppercase monospace category label (e.g. "AI / ML", "Robotics") */
.proj-category {
    font-size: 0.7em;
    font-family: monospace;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #9940FF;
}

/* Project title — color transitions to purple on card hover (see .proj-card:hover .proj-title) */
.proj-title {
    font-size: 1em;
    font-weight: 600;
    color: #C8A79C;
    line-height: 1.3;
}

/* Short project description shown on the card */
.proj-desc {
    font-size: 0.875em;
    color: #C8A79Caa;
    line-height: 1.7;
    flex: 1; /* pushes the tags and links to the bottom of the card */
}

/* Container for technology pill badges */
.proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

/* Individual technology badge pill */
.proj-tag {
    font-size: 0.72em;
    padding: 3px 10px;
    border-radius: 4px;
    background-color: #31003C;
    color: #9940FF;
    border: 1px solid #9940FF33;
    font-family: monospace;
}

/* Bottom row of each card containing icon links (e.g. GitHub).
   z-index: 2 ensures these links sit above the .proj-card-link overlay
   so they remain independently clickable. */
.proj-links {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid #9940FF22;
    margin-top: auto;
    position: relative;
    z-index: 2;
}

/* Icon-only link (GitHub, etc.) inside .proj-links */
.proj-link-icon {
    color: #C8A79C66;
    transition: color 0.2s;
    display: flex;
    align-items: center;
}

.proj-link-icon:hover {
    color: #9940FF;
}

/* Message shown when a filter returns zero matching cards */
.proj-empty {
    text-align: center;
    padding: 48px 0;
    color: #C8A79C66;
    font-family: monospace;
    font-size: 0.9em;
}

/* Calorimeter */
.detail-cal-pic1 {
    width: 100%;
    max-width: 500px;
    margin-bottom: 32px;
}

.detail-cal-pic1 .carousel-item img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center;
}

/* Crawler */
.crawler-img-sub {
    height:500px;
    width:700px;
}

/* ===== SKILLS ===== */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}

.skill-widget {
    text-align: center;
}

/* Restored to original large size */
.skill-img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    margin: 0 auto 16px;
}

.skill-name {
    color: #9940FF;
    font-size: 1.05em;
    font-weight: bold;
    margin-bottom: 10px;
}

.skill-widget .body-text {
    text-align: left;
    font-size: 0.9em;
}

/* ===== CONTACT ===== */
.contact-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: calc(100vh - 65px);
}

.contact-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

/* Icon card — same hover style as project cards (purple glow + lift) */
.contact-icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 28px 36px;
    background-color: #4C066C;
    border-radius: 12px;
    border: 1px solid #9940FF22;
    text-decoration: none;
    color: #C8A79C;
    font-size: 0.9em;
    font-weight: 500;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s, color 0.2s;
}

.contact-icon-card i {
    font-size: 2.5rem;
    color: #C8A79C;
    transition: color 0.2s;
}

/* same structure as the projects hover */
.contact-icon-card:hover {
    border-color: #9940FF;
    box-shadow: 0 0 0 1px #9940FF, 0 6px 28px #9940FF22;
    transform: translateY(-3px);
    color: #9940FF;
}

.contact-icon-card:hover i {
    color: #9940FF;
}

/* ===== PROJECT DETAIL PAGE ===== */
.detail-page {
    background-color: #31003C;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: #C8A79C;
    font-family: 'Inter', sans-serif;
}

.detail-scroll-area {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    
}

.detail-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: #31003Cee;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #9940FF22;
    padding: 0 32px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.detail-logo {
    font-family: 'Mea Culpa', cursive;
    font-size: 1.5em;
    color: #C8A79C;
    text-decoration: none;
    transition: color 0.2s;
}

.detail-logo:hover { color: #9940FF; }

.detail-main {
    max-width: 768px;
    margin: 0 auto;
    padding: 64px 32px 96px;
}

.detail-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: monospace;
    font-size: 0.85em;
    color: #C8A79C88;
    text-decoration: none;
    margin-bottom: 40px;
    transition: color 0.2s;
}

.detail-back:hover { color: #9940FF; }

.detail-back svg { flex-shrink: 0; }

.detail-category {
    font-size: 0.7em;
    font-family: monospace;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9940FF;
    display: block;
    margin-bottom: 8px;
}

.detail-title {
    font-size: 2.2em;
    font-weight: bold;
    color: #C8A79C;
    line-height: 1.15;
    margin-bottom: 16px;
}

.detail-summary {
    font-size: 1.05em;
    line-height: 1.8;
    color: #C8A79Cbb;
    margin-bottom: 28px;
}

.detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
}

.detail-tag {
    font-size: 0.75em;
    padding: 4px 12px;
    border-radius: 4px;
    background-color: #4C066C;
    color: #9940FF;
    border: 1px solid #9940FF33;
    font-family: monospace;
}

.detail-links {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 28px;
    border-bottom: 1px solid #9940FF22;
    margin-bottom: 36px;
}

.detail-gh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 8px;
    border: 1px solid #9940FF44;
    color: #C8A79C;
    text-decoration: none;
    font-size: 0.85em;
    transition: border-color 0.2s, color 0.2s, background-color 0.2s;
}

.detail-gh-btn:hover {
    border-color: #9940FF;
    color: #9940FF;
    background-color: #9940FF11;
}

.detail-img-wrap {
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #9940FF22;
    margin-bottom: 40px;
    background-color: #4C066C;
}

.detail-img-wrap img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
}

.detail-img-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9940FF44;
    font-family: monospace;
    font-size: 0.85em;
    border: 2px dashed #9940FF22;
    border-radius: 10px;
    margin-bottom: 40px;
}

.detail-body {
    font-size: 0.95em;
    line-height: 1.85;
    color: #C8A79Caa;
}

.detail-body p { margin-bottom: 20px; }

.detail-body h3 {
    color: #C8A79C;
    font-size: 1.1em;
    font-weight: 600;
    margin: 32px 0 12px;
}

/* ===== RESPONSIVE: ranging from desktops to mobile devices ===== */
@media (max-width: 900px) {
    .proj-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
    body { overflow: auto; height: auto; }

    .layout-grid { height: auto; }

    .header-inner { padding: 8px 16px; flex-wrap: wrap; }

    /* FIX: nav text labels overflow on small screens — collapse to icon-only
       by zeroing font-size (hides text nodes) and tightening padding */
    .nav-link { font-size: 0; padding: 9px 10px; gap: 0; }
    .nav-icon { width: 20px; height: 20px; }

    main { overflow: visible; }

    .page-section { min-height: auto; }

    .hero { height: auto; min-height: calc(100vh - 60px); }

    h1 { font-size: 3em; }

    .section-wrap { padding: 32px 20px; }

    .about-grid { grid-template-columns: 1fr; }
    /* FIX: profile picture was hidden on portrait mobile — changed display:none to
       a centered block so it stacks below the About Me text on small screens */
    .about-photo-widget { display: flex; justify-content: center; }
    .profile-pic { width: 120px; height: 120px; }

    .proj-grid { grid-template-columns: 1fr; }
    .proj-header { flex-direction: column; align-items: flex-start; }

    .skills-grid { grid-template-columns: 1fr; }

    .skill-img { width: 100px; height: 100px; }

    /* FIX: contact section was getting clipped on mobile because min-height was
       forcing it to 100vh — removed fixed height so it sizes naturally with padding.
       Buttons now stack full-width so they don't overflow on small screens. */
    .contact-wrap { min-height: auto; padding-top: 64px; padding-bottom: 64px; }
    .contact-row { flex-direction: column; }
    .contact-icon-card { width: 100%; flex-direction: row; justify-content: flex-start; padding: 20px 24px; }
}
